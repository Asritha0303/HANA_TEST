COLUMN TABLE TEST_ACCRULES ("Rule System ID" INTEGER ,
	 "PRIORITY" INTEGER ,
	 "Event Type" NVARCHAR(100),
	 "Cashflow Type/ Key Figure" NVARCHAR(100),
	 "ACTION" NVARCHAR(100),
	 "ACCOUNT" NVARCHAR(100),
	 "Account Name" NVARCHAR(100),
	 "COUNTERPARTY_GROUP" NVARCHAR(100),
	 "FX_DEAL_CATEGORY" NVARCHAR(100),
	 "MM_DEAL_CATEGORY" NVARCHAR(100),
	 "TRANSACTION_CURRENCY" NVARCHAR(100),
	 "PORTFOLIO" NVARCHAR(100),
	 "INSTRUMENT" NVARCHAR(100),
	 "INSTRUMENT_GROUP" NVARCHAR(100),
	 "INSTRUMENT_GROUP_PATH" NVARCHAR(100))